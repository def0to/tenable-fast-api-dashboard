TENABLE_SC_HOST=https://your-tenable-sc-host.com
TENABLE_SC_ACCESS_KEY=your-access-key
TENABLE_SC_SECRET_KEY=your-secret-key

# Security (recommended for production)
ALLOWED_ORIGINS=https://your-domain.com,https://localhost
VERIFY_SSL=true

# SMTP Configuration (for Scheduled Reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=scanman2@yourdomain.com
SMTP_TLS=true
